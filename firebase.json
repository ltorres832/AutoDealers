{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "hosting-stub",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "run": {
          "serviceId": "public-web-app",
          "region": "us-central1"
        }
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|woff|woff2|ttf|otf|eot|wasm|mjs)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=31536000"
          }
        ]
      },
      {
        "source": "/index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ],
    "cleanUrls": true,
    "trailingSlash": false
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ],
      "predeploy": [
        "npm run predeploy:functions"
      ]
    }
  ],
  "apphosting": [
    {
      "backendId": "public-web-app",
      "rootDir": "apps/public-web",
      "ignore": [
        "**/node_modules/**",
        "**/.next/**",
        "**/out/**",
        "**/.git/**",
        ".firebase/**",
        "**/.turbo/**",
        "**/coverage/**",
        "**/*.tsbuildinfo",
        "**/hosting/**",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "functions/**",
        "autodealers_flutter/**",
        "apps/admin/**",
        "apps/dealer/**",
        "apps/seller/**",
        "apps/advertiser/**",
        "apps/admin-web/**",
        "packages/**/src/**/*.js",
        "**/*.bak",
        "**/*.bak.bak"
      ]
    },
    {
      "backendId": "admin-app",
      "rootDir": "apps/admin",
      "ignore": [
        "**/node_modules/**",
        "**/.next/**",
        "**/out/**",
        ".firebase/**",
        "functions/**",
        "autodealers_flutter/**",
        "apps/public-web/**",
        "apps/dealer/**",
        "apps/seller/**",
        "apps/advertiser/**"
      ]
    },
    {
      "backendId": "dealer-app",
      "rootDir": "apps/dealer",
      "ignore": [
        "**/node_modules/**",
        "**/.next/**",
        "**/out/**",
        ".firebase/**",
        "functions/**",
        "autodealers_flutter/**",
        "apps/public-web/**",
        "apps/admin/**",
        "apps/seller/**",
        "apps/advertiser/**"
      ]
    },
    {
      "backendId": "seller-app",
      "rootDir": "apps/seller",
      "ignore": [
        "**/node_modules/**",
        "**/.next/**",
        "**/out/**",
        ".firebase/**",
        "functions/**",
        "autodealers_flutter/**",
        "apps/public-web/**",
        "apps/admin/**",
        "apps/dealer/**",
        "apps/advertiser/**"
      ]
    },
    {
      "backendId": "advertiser-app",
      "rootDir": "apps/advertiser",
      "ignore": [
        "**/node_modules/**",
        "**/.next/**",
        "**/out/**",
        ".firebase/**",
        "functions/**",
        "autodealers_flutter/**",
        "apps/public-web/**",
        "apps/admin/**",
        "apps/dealer/**",
        "apps/seller/**"
      ]
    }
  ],
  "emulators": {
    "auth": {
      "port": 9099
    },
    "firestore": {
      "port": 8080
    },
    "storage": {
      "port": 9199
    },
    "ui": {
      "enabled": true,
      "port": 4000
    },
    "singleProjectMode": true
  }
}