rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Seguimiento público de citas: doc id = token opaco; lectura anónima; solo backend escribe
    match /publicLeadAppointmentTracking/{token} {
      allow read: if true;
      allow write: if false;
    }
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && request.auth.token.role == 'admin';
    }
    
    function isOwner(tenantId) {
      return isAuthenticated() && 
             (request.auth.token.role == 'admin' || 
              request.auth.token.tenantId == tenantId ||
              // Manager y dealer_admin también son owners si tienen el mismo tenantId
              (request.auth.token.role in ['manager', 'dealer_admin'] && 
               request.auth.token.tenantId == tenantId));
    }
    
    function isDealer(tenantId) {
      return isAuthenticated() && 
             request.auth.token.role == 'dealer' && 
             request.auth.token.tenantId == tenantId;
    }
    
    // Helper para verificar si es manager o dealer_admin del tenant
    function isManagerOrAdmin(tenantId) {
      return isAuthenticated() && 
             request.auth.token.role in ['manager', 'dealer_admin'] && 
             request.auth.token.tenantId == tenantId;
    }
    
    function isSeller(tenantId) {
      return isAuthenticated() &&
             request.auth.token.role == 'seller' &&
             request.auth.token.tenantId == tenantId;
    }

    function isSellerAssignedLead() {
      return isAuthenticated() &&
             request.auth.token.role == 'seller' &&
             resource.data.assignedTo == request.auth.uid;
    }

    function isSellerLinkedToDealer() {
      return isAuthenticated() &&
             request.auth.token.keys().hasAny(['dealerId']) &&
             request.auth.token.dealerId != null &&
             request.auth.token.dealerId != '';
    }

    function isIndependentSellerTenant(tenantId) {
      return isSeller(tenantId) &&
             !isSellerLinkedToDealer() &&
             get(/databases/$(database)/documents/tenants/$(tenantId)).data.get('type', '') == 'seller';
    }
    
    // Users collection
    match /users/{userId} {
      // Permitir lectura pública solo para sellers y dealers activos (para páginas públicas)
      allow read: if true; // Público para webs (sin autenticación requerida)
      // Permitir crear usuarios si es admin, dealer creando sellers/gerentes/admin, o dealer_admin creando otros usuarios
      allow create: if isAdmin() || 
                       (isAuthenticated() && 
                        request.auth.token.role == 'dealer' &&
                        request.resource.data.tenantId == request.auth.token.tenantId &&
                        request.resource.data.role in ['seller', 'manager', 'dealer_admin']) ||
                       (isAuthenticated() && 
                        request.auth.token.role == 'dealer_admin' &&
                        request.resource.data.tenantId == request.auth.token.tenantId &&
                        request.resource.data.role in ['manager', 'dealer_admin']);
      allow update: if isAdmin() || 
                       (isAuthenticated() && request.auth.uid == userId) ||
                       (isAuthenticated() && 
                        request.auth.token.role == 'dealer_admin' &&
                        resource.data.tenantId == request.auth.token.tenantId);
      allow delete: if isAdmin() ||
                       (isAuthenticated() && 
                        request.auth.token.role == 'dealer_admin' &&
                        resource.data.tenantId == request.auth.token.tenantId);

      match /fcmTokens/{tokenId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }
    
    // Tenants collection
    match /tenants/{tenantId} {
      allow read: if true; // Público para webs (sin autenticación requerida)
      // Permitir crear tenants si es admin o si es dealer creando tenant para seller
      allow create: if isAdmin() || 
                       (isAuthenticated() && 
                        request.auth.token.role == 'dealer' &&
                        request.resource.data.type == 'seller');
      allow update: if isAdmin() || isOwner(tenantId);
      allow delete: if isAdmin();
    }

    function canConfigureTenantSettings(tenantId) {
      return isAuthenticated() &&
             request.auth.token.tenantId == tenantId &&
             request.auth.token.role in ['dealer', 'master_dealer', 'dealer_admin', 'manager'];
    }

    // Ajustes del tenant (IA, CRM routing, branding en Firestore, etc.)
    match /tenants/{tenantId}/settings/{settingId} {
      allow read: if isOwner(tenantId);
      allow create, update, delete: if isAdmin() || canConfigureTenantSettings(tenantId);
    }
    
    // Leads collection
    match /tenants/{tenantId}/leads/{leadId} {
      allow read: if isOwner(tenantId) || (isSeller(tenantId) && isSellerAssignedLead());
      allow create: if isOwner(tenantId);
      allow update: if isOwner(tenantId) || (isSeller(tenantId) && isSellerAssignedLead());
      allow delete: if isAdmin() || isDealer(tenantId) || isManagerOrAdmin(tenantId) ||
                       (isSeller(tenantId) && isSellerAssignedLead()) ||
                       isIndependentSellerTenant(tenantId);
    }

    // Señales de interés en vehículos (clics catálogo público; sin PII). Escritura solo vía Admin SDK.
    match /tenants/{tenantId}/vehicle_interest_signals/{signalId} {
      allow read: if isOwner(tenantId);
      allow create, update, delete: if false;
    }
    
    // Notificaciones in-app (tiempo real en campana)
    match /tenants/{tenantId}/notifications/{notificationId} {
      allow read: if isAuthenticated() &&
                     resource.data.userId == request.auth.uid &&
                     (isAdmin() || request.auth.token.tenantId == tenantId);
      allow update: if isAuthenticated() &&
                       resource.data.userId == request.auth.uid &&
                       (isAdmin() || request.auth.token.tenantId == tenantId);
      allow create, delete: if false;
    }

    match /tenants/{tenantId}/corporate_emails/{emailId} {
      allow read: if isAdmin() || isOwner(tenantId);
      allow create, update, delete: if isAdmin() || canConfigureTenantSettings(tenantId);
    }

    match /tenants/{tenantId}/tasks/{taskId} {
      allow read: if isAdmin() || isOwner(tenantId) || isSeller(tenantId);
      allow create: if isAdmin() || isOwner(tenantId) || isSeller(tenantId);
      allow update: if isAdmin() || isOwner(tenantId) || isSeller(tenantId);
      allow delete: if isAdmin() || isDealer(tenantId) || isManagerOrAdmin(tenantId);
    }

    match /tenants/{tenantId}/promotions/{promotionId} {
      allow read: if isAdmin() || isOwner(tenantId) || isSeller(tenantId);
      allow create, update: if isAdmin() || isOwner(tenantId) || isSeller(tenantId);
      allow delete: if isAdmin() || isDealer(tenantId) || isManagerOrAdmin(tenantId);
    }

    // Messages collection
    match /tenants/{tenantId}/messages/{messageId} {
      allow read: if isOwner(tenantId) || isSeller(tenantId);
      allow create: if isOwner(tenantId) || isSeller(tenantId);
      allow update: if isOwner(tenantId) || isSeller(tenantId);
      allow delete: if isAdmin() || isManagerOrAdmin(tenantId);
    }
    
    // Vehicles collection
    match /tenants/{tenantId}/vehicles/{vehicleId} {
      allow read: if true; // Público para webs (sin autenticación requerida)
      allow create: if isOwner(tenantId);
      allow update: if isOwner(tenantId);
      allow delete: if isAdmin() || isDealer(tenantId) || isManagerOrAdmin(tenantId);
    }
    
    // Appointments collection
    match /tenants/{tenantId}/appointments/{appointmentId} {
      allow read: if isOwner(tenantId);
      allow create: if isOwner(tenantId);
      allow update: if isOwner(tenantId);
      allow delete: if isAdmin() || isDealer(tenantId) || isManagerOrAdmin(tenantId);
    }
    
    // Sales collection
    match /tenants/{tenantId}/sales/{saleId} {
      allow read: if isOwner(tenantId);
      allow create: if isOwner(tenantId);
      allow update: if isAdmin() || isDealer(tenantId) || isManagerOrAdmin(tenantId);
      allow delete: if isAdmin() || isManagerOrAdmin(tenantId);
    }
    
    // F&I: clientes y solicitudes (mismo tenant; listeners en tiempo real en seller/dealer)
    match /tenants/{tenantId}/fi_clients/{clientId} {
      allow read: if isOwner(tenantId);
      allow create: if isOwner(tenantId);
      allow update: if isOwner(tenantId);
      allow delete: if isAdmin() || isDealer(tenantId) || isManagerOrAdmin(tenantId);
    }

    match /tenants/{tenantId}/fi_requests/{requestId} {
      allow read: if isOwner(tenantId);
      allow create: if isOwner(tenantId);
      allow update: if isOwner(tenantId);
      allow delete: if isAdmin() || isDealer(tenantId) || isManagerOrAdmin(tenantId);
    }

    // Casos de cliente (expediente; etapa F&I sincronizada)
    match /tenants/{tenantId}/customer_files/{fileId} {
      allow read: if isOwner(tenantId);
      allow create: if isOwner(tenantId);
      allow update: if isOwner(tenantId);
      allow delete: if isAdmin() || isDealer(tenantId) || isManagerOrAdmin(tenantId);
    }
    
    // Subscriptions collection
    match /subscriptions/{subscriptionId} {
      allow read: if isAuthenticated() &&
                     (isAdmin() ||
                      resource.data.tenantId == request.auth.token.tenantId);
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Idempotencia de webhooks Stripe (solo Admin SDK / servidor)
    match /stripe_webhook_events/{eventId} {
      allow read, write: if false;
    }
    
    // Memberships collection
    match /memberships/{membershipId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Invitaciones dealer ↔ vendedor (cuentas separadas). Escritura solo servidor.
    match /dealer_seller_links/{linkId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        resource.data.sellerUserId == request.auth.uid ||
        (request.auth.token.role in ['dealer', 'master_dealer', 'dealer_admin', 'manager'] &&
         resource.data.dealerTenantId == request.auth.token.tenantId)
      );
      allow write: if false;
    }

    // Códigos/link de invitación dealer ↔ vendedor. Lectura permitida al dealer dueño (para tiempo real).
    match /dealer_seller_invites/{inviteId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        (request.auth.token.role in ['dealer', 'master_dealer', 'dealer_admin', 'manager'] &&
          resource.data.dealerTenantId == request.auth.token.tenantId)
      );
      allow write: if false;
    }

    // Códigos reutilizables de invitación dealer → seller. Lectura/escritura solo servidor.
    match /dealer_seller_invite_codes/{dealerTenantId} {
      allow read, write: if false;
    }
    
    // Sub users collection (vendedores con tenant propio)
    match /sub_users/{subUserId} {
      allow read: if isAuthenticated() && 
                     (isAdmin() || 
                      resource.data.dealerTenantId == request.auth.token.tenantId ||
                      resource.data.tenantId == request.auth.token.tenantId ||
                      subUserId == request.auth.uid);
      allow create: if isAuthenticated() && 
                       (isAdmin() || 
                        request.auth.token.role == 'dealer' &&
                        request.resource.data.dealerTenantId == request.auth.token.tenantId);
      allow update: if isAdmin() || 
                       (isAuthenticated() && 
                        (request.auth.token.role == 'dealer' &&
                         resource.data.dealerTenantId == request.auth.token.tenantId) ||
                        subUserId == request.auth.uid);
      allow delete: if isAdmin();
    }
    
    // Sub users subcollection (vendedores sin tenant propio)
    match /tenants/{tenantId}/sub_users/{subUserId} {
      allow read: if isOwner(tenantId);
      allow create: if isOwner(tenantId);
      allow update: if isOwner(tenantId);
      allow delete: if isAdmin() || isDealer(tenantId) || isManagerOrAdmin(tenantId);
    }
    
    // Integrations collection
    match /tenants/{tenantId}/integrations/{integrationId} {
      allow read: if isOwner(tenantId);
      allow create: if isOwner(tenantId);
      allow update: if isOwner(tenantId);
      allow delete: if isAdmin() || isDealer(tenantId) || isManagerOrAdmin(tenantId);
    }
    
    // Templates collection
    match /templates/{templateId} {
      allow read: if isAuthenticated() && 
                     (isAdmin() || resource.data.tenantId == request.auth.token.tenantId);
      allow create: if isAuthenticated() && 
                       (isAdmin() || 
                        (request.resource.data.tenantId == request.auth.token.tenantId && 
                         request.auth.token.role in ['admin', 'dealer', 'manager', 'dealer_admin']));
      allow update: if isAuthenticated() && 
                       (isAdmin() || 
                        (resource.data.tenantId == request.auth.token.tenantId && 
                         resource.data.isEditable == true &&
                         request.auth.token.role in ['admin', 'dealer', 'manager', 'dealer_admin']));
      allow delete: if isAdmin() || 
                       (isAuthenticated() && 
                        resource.data.tenantId == request.auth.token.tenantId &&
                        request.auth.token.role in ['admin', 'dealer', 'manager', 'dealer_admin']);
    }
    
    // Audit logs collection
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update: if false; // Immutable
      allow delete: if isAdmin();
    }
    
    // Public chat messages collection (chat público desde página web)
    match /tenants/{tenantId}/public_chat_messages/{messageId} {
      allow read: if true; // Público para leer mensajes de su sesión
      allow create: if true; // Público para crear mensajes
      allow update: if isOwner(tenantId); // Solo el tenant puede actualizar (marcar como leído)
      allow delete: if isAdmin();
    }
    
    // Sponsored Content collection - Public read access
    match /sponsored_content/{contentId} {
      allow read: if true;
      allow create: if isAdmin() || isAuthenticated(); // Allow authenticated users to create ads
      allow update: if isAdmin() || (isAuthenticated() && resource.data.advertiserId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Premium Banners collection - Public read access
    match /{path=**}/premium_banners/{bannerId} {
      allow read: if true;
    }

    // Reviews collection - Public read access
    match /{path=**}/reviews/{reviewId} {
      allow read: if true;
    }

    // Leads en raíz (deprecado): el CRM usa solo tenants/{tenantId}/leads/{leadId}
    match /leads/{leadId} {
      allow read, write: if false;
    }

    // Marca global (logo/favicon): lectura pública para apps Web; escritura solo vía Admin SDK en API
    match /admin_settings/{docId} {
      allow read: if docId == 'branding';
      allow write: if false;
    }

    match /referrals/{referralId} {
      allow read: if isAuthenticated() &&
                     (resource.data.referrerId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    match /dealers/{dealerId} {
      allow read: if isAdmin() || isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /email_aliases/{aliasId} {
      allow read: if isAdmin() ||
                     (isAuthenticated() && resource.data.dealerId == request.auth.token.tenantId);
      allow create, update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read, update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create, delete: if false;
    }

    match /admin_notifications/{notificationId} {
      allow read, update: if isAdmin() && resource.data.userId == request.auth.uid;
      allow create, delete: if false;
    }

    match /admin_users/{adminUserId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /{path=**}/tasks/{taskId} {
      allow read: if isAdmin();
    }

    match /{path=**}/corporate_emails/{emailId} {
      allow read: if isAdmin();
    }

    match /reward_credits/{creditId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Formulario de contacto público — solo backend (Admin SDK)
    match /contact_inquiries/{inquiryId} {
      allow read, write: if false;
    }
  }
}
