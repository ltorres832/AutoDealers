# ============================================
# AutoDealers Platform - Variables de Entorno
# ============================================
# Copia este archivo a .env.local y completa con tus valores reales
# NUNCA subas archivos .env.local al repositorio

# --- Firebase: varios proyectos (p. ej. AutoDealers vs Rutealo) ---
# Cada despliegue debe usar SOLO credenciales de UN proyecto Firebase: las de Admin (FIREBASE_*)
# y las de cliente (NEXT_PUBLIC_*) deben venir de la misma consola > Project settings > tu app.
# No mezclar API key de un proyecto con projectId de otro.
# Si vas a limpiar apps duplicadas en la consola: haz antes backup (export Firestore, Auth, etc.).

# ============================================
# Firebase Admin SDK (Server-side)
# ============================================
# Obtén estas credenciales desde Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ============================================
# Firebase Client SDK (Web - Frontend)
# ============================================
# Obtén estas credenciales desde Firebase Console > Project Settings > General > Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef123456
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================
# NextAuth.js
# ============================================
# Genera un secreto seguro: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# ============================================
# Stripe (Pagos)
# ============================================
# Obtén estas claves desde https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Opcional: signing secret del segundo endpoint de Stripe (solo app Advertiser). Si no existe,
# se reutiliza STRIPE_WEBHOOK_SECRET / stripeWebhookSecret (comportamiento anterior).
# STRIPE_ADVERTISER_WEBHOOK_SECRET=whsec_your_advertiser_endpoint_secret_here
# Stripe: cada URL de endpoint en el Dashboard tiene su propio whsec_* (no reutilices el de otra URL).
# Admin (Next): /api/webhooks/stripe — Firestore stripeWebhookSecret o STRIPE_WEBHOOK_SECRET.
# Advertiser (Next): /api/webhooks/stripe — Firestore stripeAdvertiserWebhookSecret o
#   STRIPE_ADVERTISER_WEBHOOK_SECRET; si no, mismo secreto que Admin.
# Cloud Function stripeWebhook — STRIPE_SECRET_KEY en env; secreto webhook: STRIPE_WEBHOOK_SECRET
#   o Firestore stripeWebhookSecret (mismo documento que Admin) si no defines la variable en Functions.
# URL exacta: Firebase Console → Functions (Gen2 puede mostrar también *.run.app).

# ============================================
# Meta / Facebook / WhatsApp (webhooks)
# ============================================
# Verify token Meta (Facebook / Instagram / WhatsApp): mismo valor en Meta App → Webhooks.
# Prioridad en código: FACEBOOK_VERIFY_TOKEN o META_VERIFY_TOKEN (env) → Firestore credentials
#   metaVerifyToken (Admin → General) → whatsappWebhookVerifyToken → default_verify_token (dev).
# FACEBOOK_VERIFY_TOKEN=your-verify-token-here
# Obtén estas credenciales desde https://developers.facebook.com/
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_VERIFY_TOKEN=your-verify-token-here
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token

# ============================================
# Inteligencia Artificial
# ============================================
# Elige UNA de las siguientes opciones:

# Opción 1: OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# Opción 2: Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# ============================================
# Email (Elige UNA opción)
# ============================================

# Opción 1: SendGrid
# SENDGRID_API_KEY=SG.your-sendgrid-api-key-here

# Opción 2: Resend
# RESEND_API_KEY=re_your-resend-api-key-here

# ============================================
# SMS (Twilio)
# ============================================
# Obtén estas credenciales desde https://console.twilio.com/
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# Vercel (Opcional - Solo para despliegues en Vercel)
# ============================================
# Este token se genera automáticamente al ejecutar: vercel login
# VERCEL_OIDC_TOKEN=your-vercel-oidc-token-here

# ============================================
# Desarrollo (Opcional)
# ============================================
# Desactiva Firebase para desarrollo local (usa datos mock)
# SKIP_FIREBASE=false
