{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "incremental": true,
    "noImplicitAny": false,
    "strict": false,
    "skipLibCheck": true,
    "noEmitOnError": false,
    "declaration": true,
    "noEmit": false,
    "paths": {
      "@autodealers/core": [
        "../core/src"
      ],
      "@autodealers/core/*": [
        "../core/src/*"
      ],
      "@autodealers/shared": [
        "../shared/src"
      ],
      "@autodealers/shared/*": [
        "../shared/src/*"
      ],
      "@autodealers/crm": [
        "../crm/src"
      ],
      "@autodealers/crm/*": [
        "../crm/src/*"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.spec.ts",
    "../**"
  ],
  "files": []
}