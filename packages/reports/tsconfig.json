{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "composite": false,
    "incremental": false,
    "noImplicitAny": false,
    "strict": false,
    "skipLibCheck": true,
    "noEmitOnError": false,
    "declaration": true,
    "noEmit": false,
    "paths": {
      "@autodealers/core": ["../core/dist"],
      "@autodealers/core/*": ["../core/dist/*"],
      "@autodealers/shared": ["../shared/dist"],
      "@autodealers/shared/*": ["../shared/dist/*"],
      "@autodealers/crm": ["../crm/dist"],
      "@autodealers/crm/*": ["../crm/dist/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"]
}
