{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "declaration": true,
    "noEmit": false,
    "incremental": true,
    "skipLibCheck": true,
    "noEmitOnError": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "paths": {
      "@autodealers/shared": [
        "../shared/dist"
      ],
      "@autodealers/shared/*": [
        "../shared/dist/*"
      ],
      "@autodealers/messaging": [
        "../messaging/dist"
      ],
      "@autodealers/messaging/*": [
        "../messaging/dist/*"
      ],
      "@autodealers/billing": [
        "../billing/dist"
      ],
      "@autodealers/billing/*": [
        "../billing/dist/*"
      ],
      "@autodealers/inventory": [
        "../inventory/dist"
      ],
      "@autodealers/inventory/*": [
        "../inventory/dist/*"
      ],
      "@autodealers/crm": [
        "../crm/dist"
      ],
      "@autodealers/crm/*": [
        "../crm/dist/*"
      ],
      "@autodealers/ai": [
        "../ai/dist"
      ],
      "@autodealers/ai/*": [
        "../ai/dist/*"
      ],
      "@autodealers/reports": [
        "../reports/dist"
      ],
      "@autodealers/reports/*": [
        "../reports/dist/*"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}